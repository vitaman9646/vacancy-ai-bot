# ==============================================
#  VACANCY AI BOT - CONFIGURATION
# ==============================================

# ============ Telegram ============
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
BOT_TOKEN=7000000000:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MY_CHAT_ID=123456789

# ============ AI Provider ============
# Выбери провайдера: openrouter, groq, openai
AI_PROVIDER=openrouter

# OpenRouter (рекомендуется для Claude Sonnet 4.6)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.7-sonnet

# Groq (бесплатный альтернативный вариант)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI (если предпочитаешь GPT)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ============ n8n ============
N8N_URL=http://localhost:5678
N8N_API_KEY=n8n_api_xxxxxxxxxxxxxxxx

# ============ Настройки бизнес-логики ============
MY_HOURLY_RATE=500
MIN_PROFIT=30000
MAX_ACTIVE_PROJECTS=10
CHECK_INTERVAL=600

# ============ Мониторинг ============
CHANNELS=@kadrout
SITE_URLS=https://kadrout.ru/vacancies

# ============ База данных ============
DB_PATH=vacancies.db

# ============ Логирование ============
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# ============ Selenium (для парсинга) ============
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT=30
